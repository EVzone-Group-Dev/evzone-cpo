# Google Maps API Configuration
# Replace with your actual API key for Phase 2 implementation
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# API base URL used by fetchJson for backend requests.
VITE_API_BASE_URL=http://localhost:3000

# Enable MSW only when explicitly needed in development.
VITE_ENABLE_MSW=false

# Temporary BMS admin token used for remote kill workflow in development.
# Align this with backend expectations in evzone-backend/apps/api/src/modules/bms/bms.controller.ts.
VITE_BMS_ADMIN_TOKEN=EVZONE_SECURE_ADMIN_TOKEN
